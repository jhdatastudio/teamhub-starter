# Neon.tech PostgreSQL Connection String
# Zu finden unter: neon.tech → Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js Secret (beliebig langer zufälliger String)
# Generieren mit: openssl rand -base64 32
AUTH_SECRET="dein-geheimes-passwort-hier"

# App URL
NEXTAUTH_URL="http://localhost:3000"
